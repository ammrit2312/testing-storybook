{
  "color": {
    "blue": {
      "500": { "$type": "color", "$value": "#2563eb" },
      "600": { "$type": "color", "$value": "#1d4ed8" },
      "700": { "$type": "color", "$value": "#1e40af" }
    },
    "slate": {
      "100": { "$type": "color", "$value": "#f1f5f9" },
      "200": { "$type": "color", "$value": "#e2e8f0" },
      "300": { "$type": "color", "$value": "#cbd5e1" },
      "700": { "$type": "color", "$value": "#334155" },
      "900": { "$type": "color", "$value": "#0f172a" }
    },
    "white": { "$type": "color", "$value": "#ffffff" }
  },
  "space": {
    "1": { "$type": "dimension", "$value": "4px" },
    "2": { "$type": "dimension", "$value": "8px" },
    "3": { "$type": "dimension", "$value": "12px" },
    "4": { "$type": "dimension", "$value": "16px" }
  },
  "radius": {
    "md": { "$type": "dimension", "$value": "8px" }
  },
  "font": {
    "family": {
      "base": {
        "$type": "fontFamily",
        "$value": "-apple-system, BlinkMacSystemFont, Segoe UI, Roboto, Helvetica, Arial, sans-serif"
      }
    },
    "size": {
      "md": { "$type": "dimension", "$value": "14px" }
    },
    "weight": {
      "medium": { "$type": "fontWeight", "$value": 500 }
    },
    "lineHeight": {
      "md": { "$type": "dimension", "$value": "20px" }
    }
  },
  "button": {
    "radius": { "$type": "dimension", "$value": "{radius.md}" },
    "paddingY": { "$type": "dimension", "$value": "{space.2}" },
    "paddingX": { "$type": "dimension", "$value": "{space.4}" },
    "gap": { "$type": "dimension", "$value": "{space.2}" },
    "fontSize": { "$type": "dimension", "$value": "{font.size.md}" },
    "fontWeight": { "$type": "fontWeight", "$value": "{font.weight.medium}" },
    "primary": {
      "bg": { "$type": "color", "$value": "{color.blue.500}" },
      "bgHover": { "$type": "color", "$value": "{color.blue.600}" },
      "bgActive": { "$type": "color", "$value": "{color.blue.700}" },
      "fg": { "$type": "color", "$value": "{color.white}" },
      "border": { "$type": "color", "$value": "transparent" }
    },
    "secondary": {
      "bg": { "$type": "color", "$value": "{color.slate.100}" },
      "bgHover": { "$type": "color", "$value": "{color.slate.200}" },
      "bgActive": { "$type": "color", "$value": "{color.slate.300}" },
      "fg": { "$type": "color", "$value": "{color.slate.900}" },
      "border": { "$type": "color", "$value": "{color.slate.300}" }
    },
    "tertiary": {
      "bg": { "$type": "color", "$value": "transparent" },
      "bgHover": { "$type": "color", "$value": "{color.slate.100}" },
      "bgActive": { "$type": "color", "$value": "{color.slate.200}" },
      "fg": { "$type": "color", "$value": "{color.blue.600}" },
      "border": { "$type": "color", "$value": "transparent" }
    }
  }
}
